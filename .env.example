# Server
PORT=8080
ENV=development
SHUTDOWN_TIMEOUT=30s

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_DB=lms
POSTGRES_MAX_OPEN=25
POSTGRES_MAX_IDLE=5

# JWT
JWT_SECRET=your-secret-key-min-32-chars
JWT_EXPIRY=24h

# Jobs
JOB_WORKERS=5
JOB_QUEUE_SIZE=100

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
